# GNOME Shell settings
[org/gnome/shell]

# Enable these extensions for all users
enabled-extensions=['dash-to-dock@micxgx.gmail.com', 'monitor@astraext.github.io', 'caffeine@patapon.info', 'simplebreakreminder@castillodel.com', 'clipboard-indicator@tudmotu.com', 'blur-my-shell@aunetx']

# favourite apps 
favorite-apps=['chromium.desktop', 'org.gnome.Ptyxis.desktop', 'org.gnome.Nautilus.desktop', 'org.gnome.TextEditor.desktop', 'org.gnome.Calculator.desktop', 'code.desktop', 'com.spotify.Client.desktop', 'libreoffice-startcenter.desktop', 'steam.desktop']

# Window Management
[org/gnome/desktop/wm/preferences]
button-layout='appmenu:minimize,maximize,close'
titlebar-font='Inter Bold 11'
titlebar-uses-system-font=false
focus-mode='click'

[app-switcher]
current-workspace-only=true

# Screensaver/Lock
[org/gnome/desktop/screensaver]
lock-enabled=true
lock-animation=true

# Screenshots
[org/gnome/settings-daemon/plugins/media-keys]
custom-keybindings=['/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom1/']

[org/gnome/desktop/input-sources]
sources=[('xkb', 'gb')]

[org/gnome/desktop/interface]
clock-format='24h'

[org/gnome/Ptyxis]
interface-style='dark'

# Session idle behavior
[org/gnome/desktop/session]
idle-delay=uint32 300

# Power settings
[org/gnome/settings-daemon/plugins/power]
idle-dim=true
sleep-inactive-ac-timeout=0
sleep-inactive-ac-type='nothing'
sleep-inactive-battery-timeout=1200
sleep-inactive-battery-type='suspend'
power-saver-profile-on-low-battery=true
